# Claude (browser prototype — move to server for production)
VITE_CLAUDE_API_KEY=

# Optional: public URL of Pink Matter LP dashboard JSON (same origin or CORS-enabled).
# Vercel serverless also reads PINKMILK_LP_JSON_URL for /api/topic-sources/pinkmilk
VITE_PINKMILK_LP_JSON_URL=
PINKMILK_LP_JSON_URL=

# Local dev: Vite proxies /api to Vercel (default http://127.0.0.1:3000). Run: vercel dev
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000
